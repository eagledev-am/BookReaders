# Remote PostgreSQL Database Configuration
# Full JDBC URL format
DB_URL=jdbc:postgresql://your-remote-db-host.com:5432/bookreaders?sslmode=require
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# Remote RabbitMQ Configuration (CloudAMQP or other managed service)
# For CloudAMQP: Use the hostname from your CloudAMQP instance URL
RABBITMQ_HOST=your-rabbitmq-host.rmq.cloudamqp.com
RABBITMQ_PORT=5671
RABBITMQ_VIRTUAL_HOST=your-virtual-host
RABBITMQ_USERNAME=your-rabbitmq-username
RABBITMQ_PASSWORD=your-rabbitmq-password

# Mail Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Admin Configuration
ADMIN_EMAIL=admin@bookreaders.com
ADMIN_PASSWORD=admin123

# JWT Configuration (Generate using: openssl rand -base64 32)
JWT_SECRET_KEY=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# Base URL
APP_BASE_URL=http://localhost:8088

